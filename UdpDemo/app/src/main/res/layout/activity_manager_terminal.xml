<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activity.ManagerTerminalActivity">
    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/titleTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="产线测试终端"
            android:textColor="#333333"
            android:textStyle="bold"
            android:textSize="28sp"
            android:gravity="center" />

        <Button
            android:id="@+id/btnLock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="退出"
            android:textSize="12sp"
            android:background="@android:color/transparent"
            android:textColor="#999999"
            android:padding="8dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnScan"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text="扫码测试"
        android:textSize="22sp"
        android:textStyle="bold"
        android:backgroundTint="#2196F3"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/titleBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/deviceCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/btnScan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDeviceSn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="设备号：--"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvDeviceType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="类型：--"
                android:textSize="16sp"
                android:textColor="#666666"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvConnectStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="连接状态：等待扫码"
                android:textSize="16sp"
                android:textColor="#FF9800" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnFullTest"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:text="▶ 开始全测"
        android:textSize="28sp"
        android:textStyle="bold"
        android:backgroundTint="#4CAF50"
        android:layout_marginTop="24dp"
        android:enabled="false"
        app:layout_constraintTop_toBottomOf="@id/deviceCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ProgressBar
        android:id="@+id/testProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginTop="16dp"
        android:progressTint="#4CAF50"
        app:layout_constraintTop_toBottomOf="@id/btnFullTest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tvCurrentTest"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="请先扫码设备"
        android:textSize="18sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/testProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <TextView
        android:id="@+id/tvFinalResult"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:text=""
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvCurrentTest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvFinalResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <Button
            android:id="@+id/btnAddHub"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="✅ 入库"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:enabled="false"
            android:layout_marginEnd="8dp" />


        <Button
            android:id="@+id/btnReportIssue"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="⚠ 上报"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#F44336"
            android:visibility="gone"
            android:layout_marginStart="8dp" />


        <Button
            android:id="@+id/btnRetry"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="⟳ 重试"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#FF9800"
            android:visibility="gone"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>